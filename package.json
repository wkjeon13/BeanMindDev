    "@types/node": "^22.14.0",
    "@types/node-cron": "^3.0.11",
    "@vitejs/plugin-basic-ssl": "^2.1.4",
    "autoprefixer": "^10.4.21",
    "concurrently": "^9.2.1",
    "patch-package": "^8.0.1",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
