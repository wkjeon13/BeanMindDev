{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3002 --strictPort --host=0.0.0.0",
    "server": "npx nodemon --watch server --watch .env --ext ts --ignore public/ --exec \"tsx server/index.ts\"",
    "dev:admin": "npm run dev --prefix admin-web",
    "dev:all": "concurrently \"npm run server\" \"npm run dev\" \"npm run dev:admin\"",
    "build": "vite build",
    "build:all": "concurrently \"npm run build\" \"npm run build --prefix admin-web\"",
    "preview": "vite preview",
    "clean": "node -e \"var fs=require('fs'); fs.rmSync('dist', {recursive:true, force:true});\"",
    "lint": "tsc --noEmit",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@capacitor/android": "^8.2.0",
    "@capacitor/app": "^8.0.1",
    "@capacitor/browser": "^8.0.2",
    "@capacitor/cli": "^8.2.0",
    "@capacitor/core": "^8.2.0",
    "@capacitor/geolocation": "^8.1.0",
    "@capacitor/ios": "^8.2.0",
    "@capacitor/keyboard": "^8.0.1",
    "@capacitor/push-notifications": "^8.0.2",
    "@capacitor/share": "^8.0.1",
    "@capawesome/capacitor-apple-sign-in": "^0.1.0",
    "@capawesome/capacitor-google-sign-in": "^0.1.2",
    "@google/genai": "^1.29.0",
    "@prisma/client": "^5.22.0",
    "@react-oauth/google": "^0.13.4",
    "@revenuecat/purchases-capacitor": "^13.1.2",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.14",
    "@types/multer": "^2.1.0",
    "@types/uuid": "^10.0.0",
    "@vitejs/plugin-react": "^5.0.4",
    "apple-signin-auth": "^2.0.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.4.1",
    "bullmq": "^5.73.5",
    "cors": "^2.8.6",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "emoji-picker-react": "^4.18.0",
    "express": "^4.21.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.7.0",
    "google-auth-library": "^10.6.1",
    "helmet": "^8.1.0",
    "i18next": "^25.8.18",
    "i18next-browser-languagedetector": "^8.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "leaflet": "^1.9.4",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "multer": "^2.1.1",
    "mysqldump": "^3.2.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^8.0.1",
    "react": "^19.0.0",
    "react-daum-postcode": "^4.0.0",
    "react-dom": "^19.0.0",
    "react-i18next": "^16.5.8",
    "react-leaflet": "^5.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "react-zoom-pan-pinch": "^4.0.3",
    "recharts": "^3.8.1",
    "uuid": "^13.0.0",
    "vite": "^6.2.0",
    "winston": "^3.19.0",
