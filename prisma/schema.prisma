generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id                  String             @id @default(uuid())
  email               String             @unique
  password            String?
  nickname            String
  phone               String?            @db.Text
  role                Role               @default(USER)
  createdAt           DateTime           @default(now())
  updatedAt           DateTime           @updatedAt
  isEmailVerified     Boolean            @default(false)
  verificationCode    String?
  verificationExpires DateTime?
  status              String             @default("ACTIVE")
  loginType           String             @default("EMAIL")
  socialId            String?            @unique
  profileImageUrl     String?            @db.LongText
  failedLoginAttempts Int                @default(0)
  lockedUntil         DateTime?
  aiPrescriptionLimit Int                @default(3)
  aiUsageCount        Int                @default(0)
  ageGroup            String?
  favoriteCafe        String?
  gender              String?
  pointBalance        Int                @default(0)
  bio                 String?            @db.Text
  isPublicProfile     Boolean            @default(true)
  prefAcidity         Float?
  prefBitterness      Float?
  prefBody            Float?
  prefSweetness       Float?
  fcmToken            String?            @db.Text
  equippedBadge       String?
  earnedBadges        String?            @db.Text
  rewardTier1Name     String             @default("참여")
  rewardTier1Amount   Int                @default(10)
  rewardTier2Name     String             @default("감사")
  rewardTier2Amount   Int                @default(50)
  rewardTier3Name     String             @default("최고")
  rewardTier3Amount   Int                @default(100)
  bioMediaUrls        String?            @db.LongText
  prefAroma           String?            @db.Text
  countryCode         String             @default("KR")
  preferredLanguage   String             @default("ko")
  homeLayout          Json?
  adInquiries         AdInquiry[]
  advertiser          Advertiser?
  bookmarks           Bookmark[]
  ownedClubs          Club[]             @relation("ClubOwner")
  clubBookmarks       ClubBookmark[]
  clubMemberships     ClubMember[]
  collections         Collection[]
  comments            Comment[]
  commentReactions    CommentReaction[]
  likes               Like[]
  pointTransactions   PointTransaction[]
  pollVotes           PollVote[]
  posts               Post[]
  postBookmarks       PostBookmark[]
  prescriptions       Prescription[]
  spamLogs            SpamLog[]
  stores              Store[]
  checkIns            StoreCheckIn[]
  follows             StoreFollow[]
  reviews             StoreReview[]
  tastingNotes        TastingNote[]
  following           UserFollow[]       @relation("Following")
  followers           UserFollow[]       @relation("Followers")
}

model Prescription {
  id        String   @id @default(uuid())
  userId    String
  beanName  String
  brand     String
  aiComment String   @db.Text
  createdAt DateTime @default(now())
  title     String?
  rating    Int?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "Prescription_userId_fkey")
}

model TastingNote {
  id               String   @id @default(uuid())
  userId           String
  coffeeName       String
  brand            String?
  rawUserNote      String   @db.Text
  aiTranslatedNote String   @db.Text
  acidity          Float    @default(0)
  sweetness        Float    @default(0)
  bitterness       Float    @default(0)
  body             Float    @default(0)
  aroma            Int      @default(0)
  flavorTags       String?  @db.Text
  createdAt        DateTime @default(now())
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Bookmark {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId], map: "Bookmark_storeId_fkey")
}

model Store {
  id                    String             @id @default(uuid())
  ownerId               String
  name                  String
  address               String             @db.Text
  phone                 String?            @db.Text
  hours                 String             @db.Text
  shortDesc             String
  longDesc              String             @db.Text
  signatureBean         String
  acidity               Float
  sweetness             Float
  bitterness            Float
  body                  Float
  equipment             String
  signatureMenu         String
  dessertPairing        String
  hasDecaf              Boolean            @default(false)
  hasOatMilk            Boolean            @default(false)
  status                String             @default("PENDING")
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @updatedAt
  websiteUrl            String?
  lat                   Float?
  lng                   Float?
  approvalRequestsCount Int                @default(1)
  rejectionReason       String?            @db.Text
  mainImageUrl          String?            @db.LongText
  markerImageUrl        String?            @db.LongText
  primaryCoffeeType     CoffeeType         @default(GENERAL)
  beanNotes             String?
  beanOrigin            String?
  beanRoastLevel        String?
  coffeeMenuImageUrl    String?            @db.LongText
  popularMenuImageUrl   String?            @db.LongText
  isPremiumTop          Boolean            @default(false)
  aiReviewSummary       String?            @db.LongText
  businessNumber        String?
  ownerName             String?
  settlementAccount     String?
  planExpiresAt         DateTime?
  storePlan             StorePlan          @default(BASIC)
  hasParking            Boolean            @default(false)
  hasPetFriendly        Boolean            @default(false)
  hasPowerOutlets       Boolean            @default(false)
  hasWifi               Boolean            @default(false)
  aiRecommendCount      Int                @default(0)
  recentVisitorCount    Int                @default(0)
  viewCount             Int                @default(0)
  lastWeeklyViewReset   DateTime?
  bookmarks             Bookmark[]
  collectionItems       CollectionItem[]
  media                 Media[]
  menuItems             MenuItem[]
  posts                 Post[]
  owner                 User               @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  checkIns              StoreCheckIn[]
  followers             StoreFollow[]
  reviews               StoreReview[]
  translations          StoreTranslation[]

  @@index([ownerId], map: "Store_ownerId_fkey")
}

model Media {
  id        String   @id @default(uuid())
  storeId   String
  url       String
  type      String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId], map: "Media_storeId_fkey")
}

model MenuItem {
  id          String   @id @default(uuid())
  storeId     String
  name        String
  price       String
  description String?
  imageUrl    String?  @db.LongText
  isSignature Boolean  @default(false)
  category    String?  @default("COFFEE")
  orderIndex  Int      @default(0)
  createdAt   DateTime @default(now())
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId])
}

model StoreTranslation {
  id           String   @id @default(uuid())
  storeId      String
  languageCode String
  shortDesc    String?
  longDesc     String?  @db.Text
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([storeId, languageCode])
  @@index([storeId])
}

model EmailTemplate {
  id        String   @id @default(uuid())
  type      String   @unique
  subject   String
  body      String   @db.Text
  variables String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model StoreReview {
  id          String   @id @default(uuid())
  storeId     String
  userId      String
  taste       Float
  atmosphere  Float
  interior    Float
  service     Float
  price       Float
  cleanliness Float
  overall     Float
  content     String   @db.Text
  imageUrls   String?  @db.LongText
  earnedBeans Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  store       Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([storeId], map: "StoreReview_storeId_fkey")
  @@index([userId], map: "StoreReview_userId_fkey")
}

model StoreFollow {
  id        String   @id @default(uuid())
  userId    String
  storeId   String
  createdAt DateTime @default(now())
  store     Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId], map: "StoreFollow_storeId_fkey")
}

model UserFollow {
  id          String   @id @default(uuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())
  follower    User     @relation("Following", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Followers", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId])
  @@index([followingId])
}

model AnonymousVisitor {
  id           String   @id @default(uuid())
  visitorId    String   @unique
  visitCount   Int      @default(1)
  lastVisit    DateTime @default(now())
  createdAt    DateTime @default(now())
  aiUsageCount Int      @default(0)
  hasUsedAi    Boolean  @default(false)
}

model Report {
  id         String   @id @default(uuid())
  reporterId String
  targetId   String
  targetType String
  reason     String   @db.Text
  status     String   @default("PENDING")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Block {
  id        String   @id @default(uuid())
  blockerId String
  blockedId String
  createdAt DateTime @default(now())

  @@unique([blockerId, blockedId])
}

model PointTransaction {
  id          String   @id @default(uuid())
  userId      String
  amount      Int
  type        String
  description String
  createdAt   DateTime @default(now())
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Post {
  id                 String           @id @default(uuid())
  authorId           String
  postType           PostType         @default(NORMAL)
  content            String           @db.Text
  image              String?          @db.LongText
  cafeName           String?
  cafeLocation       String?
  cafeLat            Float?
  cafeLng            Float?
  acidity            Float?
  sweetness          Float?
  body               Float?
  bitterness         Float?
  aroma              Int?
  taggedBean         String?
  recipeData         String?          @db.LongText
  shareCount         Int              @default(0)
  isPinned           Boolean          @default(false)
  isSystemPopup      Boolean          @default(false)
  isPilgrimageLedger Boolean          @default(false)
  pinnedStartDate    DateTime?
  pinnedEndDate      DateTime?
  earnedBeans        Int              @default(0)
  storeId            String?
  attachedCourseId   String?
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  clubId             String?
  isShorts           Boolean          @default(false)
  equipmentTag       String?
  shortsCategory     String?
  isHidden           Boolean          @default(false)
  countryCode        String           @default("KR")
  collectionItems    CollectionItem[]
  comments           Comment[]
  likes              Like[]
  poll               Poll?
  attachedCourse     Collection?      @relation("PostAttachedCourse", fields: [attachedCourseId], references: [id])
  author             User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  club               Club?            @relation(fields: [clubId], references: [id], onDelete: Cascade)
  store              Store?           @relation(fields: [storeId], references: [id])
  bookmarks          PostBookmark[]

  @@index([authorId])
  @@index([storeId])
  @@index([createdAt])
  @@index([attachedCourseId], map: "Post_attachedCourseId_fkey")
  @@index([clubId], map: "Post_clubId_fkey")
}

model Comment {
  id          String            @id @default(uuid())
  postId      String
  authorId    String
  parentId    String?
  content     String            @db.Text
  imageUrl    String?           @db.LongText
  isPinned    Boolean           @default(false)
  earnedBeans Int               @default(0)
  createdAt   DateTime          @default(now())
  updatedAt   DateTime          @updatedAt
  isHidden    Boolean           @default(false)
  author      User              @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent      Comment?          @relation("CommentReplies", fields: [parentId], references: [id], onDelete: Cascade)
  replies     Comment[]         @relation("CommentReplies")
  post        Post              @relation(fields: [postId], references: [id], onDelete: Cascade)
  reactions   CommentReaction[]

  @@index([postId])
  @@index([authorId])
  @@index([parentId])
}

model CommentReaction {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  emoji     String
  createdAt DateTime @default(now())
  comment   Comment  @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, emoji])
  @@index([commentId])
  @@index([userId])
}

model Like {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model PostBookmark {
  id        String   @id @default(uuid())
  postId    String
  userId    String
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([postId, userId])
  @@index([postId])
  @@index([userId])
}

model Club {
  id              String         @id @default(uuid())
  ownerId         String
  name            String         @unique
  description     String         @db.Text
  coverImageUrl   String?        @db.LongText
  isPrivate       Boolean        @default(false)
  maxMembers      Int            @default(100)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  lat             Float?
  lng             Float?
  locationName    String?
  leftCount       Int            @default(0)
  isRecruiting    Boolean        @default(true)
  recruitDeadline DateTime?
  memberCount     Int            @default(1)
  isDeleted       Boolean        @default(false)
  countryCode     String         @default("KR")
  owner           User           @relation("ClubOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  bookmarks       ClubBookmark[]
  members         ClubMember[]
  posts           Post[]

  @@index([createdAt(sort: Desc)])
  @@index([isRecruiting])
  @@index([locationName])
  @@index([ownerId])
}

model ClubMember {
  id              String   @id @default(uuid())
  clubId          String
  userId          String
  role            ClubRole @default(MEMBER)
  joinedAt        DateTime @default(now())
  applicationData String?  @db.Text
  badges          String?
  club            Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model ClubBookmark {
  id        String   @id @default(uuid())
  clubId    String
  userId    String
  createdAt DateTime @default(now())
  club      Club     @relation(fields: [clubId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([clubId, userId])
  @@index([clubId])
  @@index([userId])
}

model Advertiser {
  id             String           @id @default(uuid())
  companyName    String
  managerName    String
  managerEmail   String
  managerPhone   String?
  businessNumber String?
  address        String?
  billingType    BillingType      @default(PREPAID)
  taxInfo        String?
  status         AdvertiserStatus @default(ACTIVE)
  grade          AdvertiserGrade  @default(STANDARD)
  memo           String?          @db.Text
  userId         String?          @unique
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt
  user           User?            @relation(fields: [userId], references: [id])
  campaigns      Campaign[]
  contracts      Contract[]
}

model Contract {
  id             String         @id @default(uuid())
  advertiserId   String
  startDate      DateTime
  endDate        DateTime
  totalBudget    Float          @default(0)
  spentBudget    Float          @default(0)
  pricingModel   PricingModel   @default(CPM)
  priceRate      Float          @default(0)
  maxImpressions Int?
  maxClicks      Int?
  status         ContractStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  name           String?
  billings       Billing[]
  campaigns      Campaign[]
  advertiser     Advertiser     @relation(fields: [advertiserId], references: [id])

  @@index([advertiserId], map: "Contract_advertiserId_fkey")
}

model Campaign {
  id              String         @id @default(uuid())
  advertiserId    String
  contractId      String
  name            String
  objective       String?
  startDate       DateTime
  endDate         DateTime
  budget          Float?
  targetCountry   String         @default("GLOBAL")
  targetLanguage  String?
  targetOS        String?
  targetAgeMin    Int?
  targetAgeMax    Int?
  targetGender    String?
  targetInterests String?
  targetDays      String?
  targetHours     String?
  status          CampaignStatus @default(ACTIVE)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  creatives       AdCreative[]
  advertiser      Advertiser     @relation(fields: [advertiserId], references: [id])
  contract        Contract       @relation(fields: [contractId], references: [id])

  @@index([advertiserId], map: "Campaign_advertiserId_fkey")
  @@index([contractId], map: "Campaign_contractId_fkey")
}

model AdCreative {
  id              String         @id @default(uuid())
  campaignId      String
  name            String
  type            AdType
  size            AdSize
  content         String         @db.Text
  linkUrl         String?
  flavorTags      String?
  originTags      String?
  cpcPrice        Float?
  priority        Int            @default(1)
  weight          Int            @default(1)
  status          CreativeStatus @default(ACTIVE)
  overlayText     String?        @db.Text
  overlayFontSize Int?
  overlayColor    String?
  overlayPosition String?
  placementId     String?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  campaign        Campaign       @relation(fields: [campaignId], references: [id])
  placement       Placement?     @relation(fields: [placementId], references: [id])
  logs            AdLog[]

  @@index([campaignId], map: "AdCreative_campaignId_fkey")
  @@index([placementId], map: "AdCreative_placementId_fkey")
}

model Placement {
  id             String       @id @default(uuid())
  name           String
  locationKey    String       @unique
  supportedSizes String
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  creatives      AdCreative[]
}

model AdLog {
  id              String       @id @default(uuid())
  creativeId      String
  actionType      AdActionType
  userId          String?
  ipAddress       String?
  userAgent       String?
  deviceOS        String?
  locationCountry String?
  createdAt       DateTime     @default(now())
  creative        AdCreative   @relation(fields: [creativeId], references: [id])

  @@index([creativeId], map: "AdLog_creativeId_fkey")
}

model Billing {
  id               String        @id @default(uuid())
  contractId       String
  periodStart      DateTime
  periodEnd        DateTime
  totalImpressions Int           @default(0)
  totalClicks      Int           @default(0)
  totalAmount      Float         @default(0)
  tax              Float         @default(0)
  status           BillingStatus @default(PENDING)
  taxIssued        Boolean       @default(false)
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  contract         Contract      @relation(fields: [contractId], references: [id])

  @@index([contractId], map: "Billing_contractId_fkey")
}

model AdInquiry {
  id           String        @id @default(uuid())
  advertiser   String
  content      String        @db.Text
  contactName  String
  contactPhone String
  contactEmail String
  status       InquiryStatus @default(PENDING)
  adminMemo    String?       @db.Text
  userId       String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  user         User?         @relation(fields: [userId], references: [id])

  @@index([userId], map: "AdInquiry_userId_fkey")
}

model Poll {
  id        String       @id @default(uuid())
  postId    String       @unique
  question  String
  expiresAt DateTime?
  createdAt DateTime     @default(now())
  post      Post         @relation(fields: [postId], references: [id], onDelete: Cascade)
  options   PollOption[]
}

model PollOption {
  id     String     @id @default(uuid())
  pollId String
  text   String
  poll   Poll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  votes  PollVote[]

  @@index([pollId])
}

model PollVote {
  id        String     @id @default(uuid())
  userId    String
  optionId  String
  createdAt DateTime   @default(now())
  option    PollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, optionId])
  @@index([optionId])
  @@index([userId])
}

model Collection {
  id                 String           @id @default(uuid())
  userId             String
  name               String
  description        String?          @db.Text
  isPublic           Boolean          @default(true)
  isPilgrimageCourse Boolean          @default(false)
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  user               User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  items              CollectionItem[]
  attachedPosts      Post[]           @relation("PostAttachedCourse")

  @@index([userId])
}

model CollectionItem {
  id           String     @id @default(uuid())
  collectionId String
  postId       String?
  storeId      String?
  createdAt    DateTime   @default(now())
  orderIndex   Int        @default(0)
  collection   Collection @relation(fields: [collectionId], references: [id], onDelete: Cascade)
  post         Post?      @relation(fields: [postId], references: [id], onDelete: Cascade)
  store        Store?     @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([collectionId, postId])
  @@unique([collectionId, storeId])
  @@index([postId])
  @@index([storeId])
  @@index([collectionId])
}

model StoreCheckIn {
  id           String   @id @default(uuid())
  userId       String
  storeId      String
  createdAt    DateTime @default(now())
  lat          Float?
  lng          Float?
  memo         String?  @db.Text
  memoImageUrl String?  @db.LongText
  updatedAt    DateTime @default(now()) @updatedAt
  store        Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId])
  @@index([storeId])
  @@index([userId])
}

model BannedWord {
  id        String   @id @default(uuid())
  word      String   @unique
  locale    String   @default("ko")
  category  String   @default("PROFANITY")
  createdAt DateTime @default(now())
}

model SpamLog {
  id        String   @id @default(uuid())
  userId    String
  action    String
  content   String   @db.Text
  reason    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model DailyCheckIn {
  id        String   @id @default(uuid())
  userId    String
  beansWon  Int
  createdAt DateTime @default(now())

  @@index([userId])
}

model FlashDrop {
  id           String   @id @default(uuid())
  title        String
  description  String   @db.Text
  imageUrl     String   @db.LongText
  linkUrl      String?
  startTime    DateTime
  endTime      DateTime
  maxQuantity  Int      @default(0)
  claimedCount Int      @default(0)
  status       String   @default("ACTIVE")
  createdAt    DateTime @default(now())
}

enum StorePlan {
  BASIC
  PREMIUM
}

enum CoffeeType {
  SINGLE_ORIGIN
  BLENDED
  SPECIALTY_ROASTERY
  GENERAL
}

enum PostType {
  NORMAL
  ANNOUNCEMENT
  EVENT
}

enum Role {
  USER
  OWNER
  ADMIN
  MODERATOR
}

enum ClubRole {
  OWNER
  ADMIN
  EVENT_MANAGER
  CONTENT_MANAGER
